{
  "name": "feature-flag-hints",
  "displayName": "Feature Flag Hints",
  "description": "Shows the production state of Flipt feature flags inline in Go code",
  "version": "1.0.0",
  "publisher": "webvaha",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:go"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Feature Flag Hints",
      "properties": {
        "featureFlagHints.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable feature flag inlay hints"
        },
        "featureFlagHints.filePath": {
          "type": "string",
          "default": "feature-flags.json",
          "description": "Path to the feature flags JSON file (relative to workspace root)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.3",
    "@vscode/test-electron": "^2.2.0"
  },
  "dependencies": {}
}
